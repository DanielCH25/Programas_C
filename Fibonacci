#include <stdio.h>

#define N 20

// 1. ESTO ES EL PROTOTIPO: Le avisa al compilador que esta función
// existe y está escrita más abajo.
float fibonacci(void);

int main(){
    printf("Sucesion de Fibonacci: \n");
    printf("%d, %d, ", 1, 1);

    for(int i=1; i<=N; i++){
        // Aquí llamas a la función (Fila 12 aprox).
        // Como pusiste el prototipo arriba, ya no da error.
        printf("%5.0f, ", fibonacci());

        if(i % 10 == 0) {
            printf("\n");
        }
    }

    printf("\n");
    return 0;
}

// 2. AQUÍ ESTÁ LA FUNCIÓN (debajo del main)
float fibonacci(void){
    static float x1=1, x2=1;
    float x;
    x = x1 + x2;
    x1=x2;
    x2=x;
    return x;
}
