#include <stdio.h>

int main() {
    int n, temp;

    printf("=== ORDENAR VECTOR DE MAYOR A MENOR ===\n");
    printf("¿Cuántos números vas a ingresar?: "); scanf("%d", &n);

    int vector[n];

    for (int i=0; i < n; i++) {
        printf("Número %d: ", i + 1);
        scanf("%d", &vector[i]);
    }

    for (int i=0; i < n-1 ; i++) {
        for (int j=0; j < n-1 ; j++) {
            if (vector[j] < vector[j + 1]) {
                temp = vector[j];          // Guardamos el valor actual en una caja temporal
                vector[j] = vector[j + 1]; // Pasamos el más grande a la izquierda
                vector[j + 1] = temp;      // Ponemos el que guardamos en la derecha
            }
        }
    }

    printf("\nVector ordenado de mayor a menor:\n[ ");
    for (int i = 0; i < n; i++) {
        printf("%d ", vector[i]);
    }
    printf("]\n");

    return 0;
}
