#include <stdio.h>


void comprobarCapicua(int numero) {
    int original = numero;
    int invertido = 0;
    int digito;

    if (numero < 0) {
        numero = -numero;
        original = numero; 
    }

    while (numero > 0) {
        digito = numero % 10;                // 1. Sacas el último (el resto)
        invertido = (invertido * 10) + digito; // 2. Lo vas "empujando" a la izquierda
        numero = numero / 10;                 // 3. Quitas el último del original
    }

    if (original == invertido) {
        printf("El numero %d SI es capicua.\n", original);
    } else {
        printf("El numero %d NO es capicua.\n", original);
    }
}

int main() {
    int n;
    printf("Introduce un numero: ");
    scanf("%d", &n);

    comprobarCapicua(n);

    return 0;
}
