#include <stdio.h>

int main() {
    int n;
    printf("--- SUMA DE FILAS DE UNA MATRIZ ---\n");
    printf("Ingresa el tamaño de la matriz (N): ");
    scanf("%d", &n);

    int matriz[n][n];
    printf("\nIngresa los elementos de la matriz:\n");
    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            printf("Posicion [%d][%d]: ", i + 1, j + 1);
            scanf("%d", &matriz[i][j]);
        }
    }
    printf("\n--- RESULTADOS ---\n");
    for (int i = 0; i < n; i++) {
        int sumaFila = 0;

        printf("Fila %d: [ ", i + 1);
        
        for (int j = 0; j < n; j++) {
            printf("%d ", matriz[i][j]);
            sumaFila += matriz[i][j];   
        }
        printf("]--->Suma de la fila: %d\n", sumaFila);
    }

    return 0;
}
